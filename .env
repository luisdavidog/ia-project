# ==========================================
# Copiloto Nordeste - Configuración de Entorno
# ==========================================

# 1. Credenciales de Inteligencia Artificial (Obligatorio)
# Utilizado por @google/genai en src/agent/react_loop.ts y mcp_client.ts
GEMINI_API_KEY="..."

# 2. Rutas de Datos y Conocimiento (Recomendado)
# Externalizar estas rutas evita hardcodear paths en tus repositorios/servicios
DB_PATH="./data/nordeste_ops.sqlite"
DOCS_PATH="./docs"

# 3. Configuración del Servidor MCP (Opcional para este MVP)
# Aunque usamos stdio, definir el puerto/host prepara el terreno para 
# una futura migración a transporte HTTP/SSE.
MCP_SERVER_NAME="nordeste-ops-api"
# MCP_PORT=3000 

# 4. Entorno y Trazabilidad
# Útil para condicionar el nivel de "console.log" de tu bucle ReAct
NODE_ENV="development"
LOG_LEVEL="debug"

# 5. API Mock de Operaciones Nordeste
NORDESTE_API_BASE_URL=http://127.0.0.1:8000
NORDESTE_API_TOKEN=nordeste-demo-key-2025
